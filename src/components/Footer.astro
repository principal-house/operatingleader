---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} The Operating Leader</p>
		<p class="author">By <a href="https://www.linkedin.com/in/janisr/" target="_blank">Janis Rozenblats</a></p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2.5em 1em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	p {
		margin: 0;
		font-size: 0.8em;
		color: var(--text-faint);
	}
	a {
		color: var(--text-muted);
		text-decoration: none;
	}
	a:hover { color: var(--accent); }
	@media (max-width: 480px) {
		.footer-inner { flex-direction: column; gap: 0.25em; }
	}
</style>
