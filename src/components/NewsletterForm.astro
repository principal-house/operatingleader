---
interface Props {
	compact?: boolean;
}
const { compact = false } = Astro.props;
---

<!-- 
  MailerLite Integration
  Replace MAILERLITE_FORM_ACTION_URL with your MailerLite embedded form action URL.
  To find it: MailerLite → Forms → Embedded forms → Create/edit → Get HTML code → copy the form action URL.
  Also replace MAILERLITE_GROUP_ID with your subscriber group ID if needed.
-->
<form action="MAILERLITE_FORM_ACTION_URL" method="POST" class:list={["nl-form", { compact }]}>
	<input type="hidden" name="group" value="MAILERLITE_GROUP_ID" />
	<div class="nl-input-row">
		<input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
		<button type="submit">Subscribe</button>
	</div>
	{!compact && <p class="nl-privacy">One email per week. Unsubscribe anytime.</p>}
</form>

<style>
	.nl-form {
		margin-top: 1.5em;
	}
	.nl-input-row {
		display: flex;
		gap: 0.5em;
		max-width: 420px;
	}
	.nl-input-row input[type="email"] {
		flex: 1;
		padding: 0.7em 1em;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text);
		font-size: 0.9em;
		outline: none;
		transition: border-color 0.15s;
	}
	.nl-input-row input[type="email"]:focus {
		border-color: var(--accent);
	}
	.nl-input-row input[type="email"]::placeholder {
		color: var(--text-faint, #555);
	}
	.nl-input-row button {
		padding: 0.7em 1.5em;
		background: var(--accent);
		color: #1a1a1a;
		border: none;
		border-radius: 6px;
		font-weight: 600;
		font-size: 0.9em;
		cursor: pointer;
		white-space: nowrap;
		transition: opacity 0.15s;
	}
	.nl-input-row button:hover {
		opacity: 0.85;
	}
	.nl-privacy {
		margin: 0.6em 0 0;
		font-size: 0.75em;
		color: var(--text-faint, #555);
	}
	@media (max-width: 480px) {
		.nl-input-row {
			flex-direction: column;
		}
	}
</style>
