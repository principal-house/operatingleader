---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo"><img src="/images/ol-logo.png" alt="The Operating Leader" class="logo-img" /> The Operating Leader</a>
		<div class="nav-links">
			<HeaderLink href="/blog">Articles</HeaderLink>
			<HeaderLink href="/subscribe">Subscribe</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a href="https://www.linkedin.com/in/janisr/" target="_blank" aria-label="LinkedIn" class="social">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(10, 10, 10, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 720px;
		margin: 0 auto;
		padding: 0 1em;
		height: 56px;
	}
	.logo {
		font-size: 0.95em;
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.logo { display: flex; align-items: center; gap: 0.5em; }
	.logo-img { width: 28px; height: 28px; border-radius: 4px; }
	.logo:hover { color: var(--accent); }
	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}
	.nav-links a {
		font-size: 0.88em;
		color: var(--text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.15s ease;
	}
	.nav-links a:hover, .nav-links a.active {
		color: var(--text);
	}
	.social { display: flex; align-items: center; }
</style>
